# Mac Mini relay configuration.
# Copy to .env (gitignored) and fill in.

# Port for the local HTTP server (bind is 127.0.0.1 only, exposed via Cloudflare Tunnel)
PORT=8787

# Shared secret. The deployed PM Platform on Vercel must send this in:
#   Authorization: Bearer <RELAY_SHARED_SECRET>
# Generate with: openssl rand -hex 32
RELAY_SHARED_SECRET=

# Supabase project (same as the PM Platform). The relay uses the service-role
# key because it bypasses RLS - we trust requests because they pass the shared
# secret above.
SUPABASE_URL=https://sksfyygufnnbzrmneccx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Claude Agent SDK OAuth token, generated by running on this Mac Mini:
#   claude setup-token
# This is a one-year token that lets the SDK draw from Phil's Claude subscription.
CLAUDE_CODE_OAUTH_TOKEN=

# Optional: override the model. Defaults to claude-sonnet-4-5.
# CLAUDE_MODEL=claude-sonnet-4-5
