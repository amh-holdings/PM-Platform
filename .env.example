# Supabase - all three values come from the Supabase dashboard.
# Project URL and anon key are also embedded in the client bundle (NEXT_PUBLIC_*),
# so the anon key is safe to commit if needed. The service role key MUST stay secret -
# it bypasses RLS. Put it directly into Vercel's env var UI, never in a committed file.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mac Mini relay (Stage C: chat feature).
# RELAY_URL is the public HTTPS URL of the Cloudflare Tunnel that points at
# the Mac Mini's local relay server on port 8787. e.g.
# https://relay.amh.holdings or https://<random>.trycloudflare.com
RELAY_URL=
# RELAY_SHARED_SECRET must match the value set in pm-platform/relay/.env
RELAY_SHARED_SECRET=
