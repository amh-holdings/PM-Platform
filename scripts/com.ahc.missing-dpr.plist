<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.ahc.missing-dpr</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/amh_holdings/bin/missing-dpr-cron.sh</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/amh_holdings/.nvm/versions/node/v24.15.0/bin:/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>/Users/amh_holdings</string>
    </dict>

    <!-- 7:30 AM local time daily, after the morning brief at 7:00 AM. -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>7</integer>
        <key>Minute</key>
        <integer>30</integer>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/Users/amh_holdings/Library/Logs/ahc-missing-dpr.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/amh_holdings/Library/Logs/ahc-missing-dpr.err.log</string>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
